{
  "name": "homi",
  "version": "0.1.0",
  "private": true,
  "description": "HOMI v3 - the operating system for shared living",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "dev:api": "npm run dev --workspace @homi/api",
    "dev:worker": "npm run dev --workspace @homi/worker",
    "demo:api": "DATABASE_URL=postgres://homi@localhost:5433/homi REDIS_URL=redis://localhost:6379 MAGIC_LINK_PER_EMAIL=100 npm run dev --workspace @homi/api",
    "demo:web": "npm run dev --workspace @homi/web",
    "demo:seed": "node apps/api/scripts/seed-demo.mjs",
    "db:generate": "npm run generate --workspace @homi/db",
    "db:migrate": "npm run migrate --workspace @homi/db"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "eslint": "^9.30.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  }
}
