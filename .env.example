# API
PORT=3000
NODE_ENV=development

# Postgres (docker compose defaults)
DATABASE_URL=postgres://homi:homi@localhost:5432/homi

# Redis
REDIS_URL=redis://localhost:6379

# Object storage (MinIO locally, GCS in prod)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=homi
S3_SECRET_KEY=homi-dev-secret
S3_BUCKET=homi-media

# Dev-only auth shim (replaced by Better Auth in HOMI-2)
DEV_AUTH_ENABLED=true
