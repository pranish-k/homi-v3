# API
PORT=3000
NODE_ENV=development

# Postgres (docker compose defaults)
DATABASE_URL=postgres://homi:homi@localhost:5432/homi

# Redis
REDIS_URL=redis://localhost:6379

# Object storage (MinIO locally, GCS in prod)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=homi
S3_SECRET_KEY=homi-dev-secret
S3_BUCKET=homi-media

# Better Auth (HOMI-2). Magic-link URLs are logged server-side until a
# transactional email provider is wired (HOMI-21).
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=homi-dev-secret-do-not-use-in-prod
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Invite links (HOMI-8)
INVITE_LINK_ORIGIN=https://homi.app
